# --- Server ---
PORT=4000
NODE_ENV=development

# --- MongoDB (Atlas or local) ---
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/fln?retryWrites=true&w=majority
# Local: mongodb://127.0.0.1:27017/fln
# Zero-setup dev (embedded MongoDB, no install/network needed): memory
MONGODB_URI=mongodb://127.0.0.1:27017/fln

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- CORS (comma-separated) ---
CLIENT_ORIGIN=http://localhost:5173
