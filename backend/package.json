{
  "name": "@fln/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:old": "tsx src/index.ts",
    "dev:new": "tsx src/server.ts",
    "dev": "concurrently -n old,new -c yellow,cyan \"npm run dev:old\" \"npm run dev:new\"",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit",
    "seed": "tsx src/seed.ts",
    "seed:geo": "tsx src/utils/seedGeo.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "jszip": "^3.10.1",
    "mongodb": "^6.12.0",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^25.3.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.14.0",
    "concurrently": "^10.0.3",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
